rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 기존 규칙 (만족도조사)
    match /courses/{courseId} {
      allow read: if true;
      allow write: if false;
    }

    match /courses/{courseId}/instructors/{instructorId} {
      allow read: if true;
      allow write: if false;
    }

    match /courses/{courseId}/students/{studentId} {
      allow read: if true;
      allow write: if false;
    }

    match /responses/{responseId} {
      allow read: if false;
      allow create: if true;
    }

    // 출결관리
    match /attendance_logs/{logId} {
      allow read: if true;    // 관리자 실시간 현황 및 교육생 중복 확인용
      allow create: if true;  // 교육생 QR 출석 등록 허용
    }
  }
}
