rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자: Firebase Email 인증 사용자
    function isAdmin() {
      return request.auth != null && request.auth.token.email != null;
    }

    // 인증된 사용자: 관리자 + 익명(교육생)
    function isAuthenticated() {
      return request.auth != null;
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      // 강사 정보 (설문 문항 생성에 필요)
      match /instructors/{instructorId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }

      // 수강생 정보 (익명 교육생은 읽기·완료처리만, 관리자는 전체)
      match /students/{studentId} {
        allow read: if isAuthenticated();
        allow create: if isAdmin();
        allow update: if isAuthenticated(); // 교육생 설문 완료 처리
        allow delete: if isAdmin();
      }

      // 설문 응답 (관리자만 읽기·삭제, 익명 교육생은 제출만)
      match /responses/{responseId} {
        allow read: if isAdmin();
        allow create: if isAuthenticated();
        allow delete: if isAdmin();
      }

      // 출석 설정
      match /attendanceConfig/{doc} {
        allow read, write: if isAuthenticated();
      }

      // 출석 기록
      match /attendance/{attendanceId} {
        allow read, write: if isAuthenticated();
      }

    }

    // QR 토큰 (출석 체크인용)
    match /qr_tokens/{tokenId} {
      allow read, write: if isAuthenticated();
    }

    // 기기 잠금 초기화 (관리자가 생성, 교육생이 읽고 삭제)
    match /attendanceResets/{docId} {
      allow read, delete: if isAuthenticated();
      allow create, update: if isAuthenticated();
    }

    // collectionGroup 쿼리용 (교육생 로그인 시 단일 쿼리 검색)
    match /{path=**}/students/{studentId} {
      allow read: if isAuthenticated();
    }

    // collectionGroup 쿼리용 (출석 현황 조회)
    match /{path=**}/attendance/{attendanceId} {
      allow read: if isAuthenticated();
    }

  }
}
