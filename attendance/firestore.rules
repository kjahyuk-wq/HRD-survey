rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────── 헬퍼 ─────────────
    // 관리자: 명시적 이메일 화이트리스트.
    // 추가/변경 시 이 리스트와 attendance/functions/index.js 의 ADMIN_EMAILS 를 함께 수정.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'kjahyuk@korea.kr',
        ];
    }
    // 인증된 사용자: 관리자 + 익명(교육생/키오스크)
    function isAuthenticated() {
      return request.auth != null;
    }
    // 출결 학생 식별 인증 (custom token claims.role == 'student')
    function isAttendanceStudent() {
      return request.auth != null
        && request.auth.token.role == 'student';
    }
    // 변경된 키가 허용 목록에만 속하는지 (부분 업데이트 검증)
    function changedKeysOnly(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ───────────── courses ─────────────
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      // 강사 정보 (설문 문항 생성에 사용)
      match /instructors/{instructorId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }

      // 수강생: 관리자만 등록/삭제, 본인이 설문 완료 처리만 가능
      // - 단기과정: completed/completedAt 변경 (한 번만)
      // - 중견리더 회차과정: completedRounds(arrayUnion)/completedAt 변경 (회차마다)
      match /students/{studentId} {
        allow read: if isAuthenticated();
        allow create, delete: if isAdmin();
        allow update: if isAdmin()
          || (isAuthenticated()
              && (
                (changedKeysOnly(['completed', 'completedAt'])
                  && request.resource.data.completed == true)
                || (changedKeysOnly(['completedRounds', 'completedAt'])
                  && request.resource.data.completedRounds is list)
              ));
      }

      // 설문 응답: 관리자만 read/delete, 익명 교육생은 검증된 형식으로만 create
      match /responses/{responseId} {
        allow read, update, delete: if isAdmin();
        allow create: if isAdmin() || (
          isAuthenticated()
          && request.resource.data.keys().hasAll([
              'name','empNo','course',
              'q1','q2','q3','q4','q5','q6','q7','q8','q9',
              'q11','q12','q13','q14','q15','q16',
              'instructors','submittedAt'
            ])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 50
          && request.resource.data.empNo is string
          && request.resource.data.empNo.size() <= 20
          && request.resource.data.course is string
          && request.resource.data.course.size() <= 200
          && request.resource.data.q1 is int && request.resource.data.q1 >= 1 && request.resource.data.q1 <= 5
          && request.resource.data.q2 is int && request.resource.data.q2 >= 1 && request.resource.data.q2 <= 5
          && request.resource.data.q3 is int && request.resource.data.q3 >= 1 && request.resource.data.q3 <= 5
          && request.resource.data.q4 is int && request.resource.data.q4 >= 1 && request.resource.data.q4 <= 5
          && request.resource.data.q5 is int && request.resource.data.q5 >= 1 && request.resource.data.q5 <= 5
          && request.resource.data.q6 is int && request.resource.data.q6 >= 1 && request.resource.data.q6 <= 5
          && request.resource.data.q7 is int && request.resource.data.q7 >= 1 && request.resource.data.q7 <= 5
          && request.resource.data.q8 is int && request.resource.data.q8 >= 1 && request.resource.data.q8 <= 5
          && request.resource.data.q9 is int && request.resource.data.q9 >= 1 && request.resource.data.q9 <= 5
          && request.resource.data.q11 is string && request.resource.data.q11.size() <= 50
          && request.resource.data.q12 is string && request.resource.data.q12.size() <= 50
          && request.resource.data.q13 is string && request.resource.data.q13.size() <= 50
          && request.resource.data.q14 is string && request.resource.data.q14.size() <= 50
          && request.resource.data.q15 is string && request.resource.data.q15.size() <= 50
          && request.resource.data.q16 is string && request.resource.data.q16.size() <= 50
          && request.resource.data.instructors is map
          && (!('q10_comment' in request.resource.data)
              || (request.resource.data.q10_comment is string
                  && request.resource.data.q10_comment.size() <= 1000))
          && (!('comment1' in request.resource.data)
              || (request.resource.data.comment1 is string
                  && request.resource.data.comment1.size() <= 2000))
          && (!('comment2' in request.resource.data)
              || (request.resource.data.comment2 is string
                  && request.resource.data.comment2.size() <= 2000))
          && (!('comment3' in request.resource.data)
              || (request.resource.data.comment3 is string
                  && request.resource.data.comment3.size() <= 2000))
        );
      }

      // 출석 설정: 관리자만 쓰기. reset_* 마커는 본인 empNo 의 문서만 학생이 소비 후 삭제 가능.
      // (이전에는 익명 인증 누구나 reset_* 를 삭제할 수 있어 다른 학생의 lock 해제를 방해할 수 있었음)
      match /attendanceConfig/{docId} {
        allow read: if isAuthenticated();
        allow create, update: if isAdmin();
        allow delete: if isAdmin()
          || (isAttendanceStudent()
              && docId.matches('reset_.*')
              && 'empNos' in request.auth.token
              && resource.data.empNo in request.auth.token.empNos);
      }

      // 출결 학생 명단: 메일 평문 절대 저장 금지. Cloud Function 우회 등록만 안전.
      // - read: 관리자만 (학생 본인은 collectionGroup 으로 검색하지 않음 — Cloud Function이 처리)
      // - write: 관리자만, 평문 메일 필드 차단. email_hmac 은 옵셔널 (공무직 등 메일 없는 학생).
      match /attendance_students/{studentId} {
        allow read: if isAdmin();
        allow create: if isAdmin()
          && !('email' in request.resource.data)
          && !('email_plain' in request.resource.data)
          && request.resource.data.keys().hasAll(['name', 'empNo'])
          && (!('email_hmac' in request.resource.data)
              || (request.resource.data.email_hmac is string
                  && request.resource.data.email_hmac.size() == 64));
        allow update: if isAdmin()
          && !('email' in request.resource.data)
          && !('email_plain' in request.resource.data);
        allow delete: if isAdmin();
      }

      // 회차 (중견리더 양성과정 전용): 회차 CRUD는 관리자, 읽기는 인증 사용자 전체
      match /rounds/{roundId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();

        // 회차별 강사: 설문 문항 생성에 필요 → 인증 사용자 read 허용, 쓰기는 관리자
        match /instructors/{instructorId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin();
        }

        // 회차별 응답: 관리자만 read/update/delete, 익명 교육생은 검증된 형식으로만 create
        // 단기 응답과 동일 검증 + roundNumber/roundName 박제
        match /responses/{responseId} {
          allow read, update, delete: if isAdmin();
          allow create: if isAdmin() || (
            isAuthenticated()
            && request.resource.data.keys().hasAll([
                'name','empNo','course','roundNumber','roundName',
                'q1','q2','q3','q4','q5','q6','q7','q8','q9',
                'q11','q12','q13','q14','q15','q16',
                'instructors','submittedAt'
              ])
            && request.resource.data.name is string
            && request.resource.data.name.size() > 0
            && request.resource.data.name.size() <= 50
            && request.resource.data.empNo is string
            && request.resource.data.empNo.size() <= 20
            && request.resource.data.course is string
            && request.resource.data.course.size() <= 200
            && request.resource.data.roundNumber is int
            && request.resource.data.roundNumber >= 1
            && request.resource.data.roundNumber <= 99
            && request.resource.data.roundName is string
            && request.resource.data.roundName.size() <= 100
            && request.resource.data.q1 is int && request.resource.data.q1 >= 1 && request.resource.data.q1 <= 5
            && request.resource.data.q2 is int && request.resource.data.q2 >= 1 && request.resource.data.q2 <= 5
            && request.resource.data.q3 is int && request.resource.data.q3 >= 1 && request.resource.data.q3 <= 5
            && request.resource.data.q4 is int && request.resource.data.q4 >= 1 && request.resource.data.q4 <= 5
            && request.resource.data.q5 is int && request.resource.data.q5 >= 1 && request.resource.data.q5 <= 5
            && request.resource.data.q6 is int && request.resource.data.q6 >= 1 && request.resource.data.q6 <= 5
            && request.resource.data.q7 is int && request.resource.data.q7 >= 1 && request.resource.data.q7 <= 5
            && request.resource.data.q8 is int && request.resource.data.q8 >= 1 && request.resource.data.q8 <= 5
            && request.resource.data.q9 is int && request.resource.data.q9 >= 1 && request.resource.data.q9 <= 5
            && request.resource.data.q11 is string && request.resource.data.q11.size() <= 50
            && request.resource.data.q12 is string && request.resource.data.q12.size() <= 50
            && request.resource.data.q13 is string && request.resource.data.q13.size() <= 50
            && request.resource.data.q14 is string && request.resource.data.q14.size() <= 50
            && request.resource.data.q15 is string && request.resource.data.q15.size() <= 50
            && request.resource.data.q16 is string && request.resource.data.q16.size() <= 50
            && request.resource.data.instructors is map
            && (!('q10_comment' in request.resource.data)
                || (request.resource.data.q10_comment is string
                    && request.resource.data.q10_comment.size() <= 1000))
            && (!('comment1' in request.resource.data)
                || (request.resource.data.comment1 is string
                    && request.resource.data.comment1.size() <= 2000))
            && (!('comment2' in request.resource.data)
                || (request.resource.data.comment2 is string
                    && request.resource.data.comment2.size() <= 2000))
            && (!('comment3' in request.resource.data)
                || (request.resource.data.comment3 is string
                    && request.resource.data.comment3.size() <= 2000))
            && (!('groupName' in request.resource.data)
                || (request.resource.data.groupName is string
                    && request.resource.data.groupName.size() <= 50))
          );
        }
      }

      // 출석 기록: 키오스크가 관리자 계정으로 로그인해 처리하므로 관리자 전용.
      // (이전에는 익명 분기가 있었으나, 키오스크가 admin 인증을 거치므로 불필요해져 제거)
      match /attendance/{attendanceId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAdmin();
      }
    }

    // ───────────── QR 토큰 (top-level) ─────────────
    // - create: 출결 식별 인증 학생만 (본인 uid + 본인 empNo claim 만 박을 수 있음)
    // - update: 키오스크가 admin 계정으로 used 처리 → 관리자 전용
    // - delete: 관리자만
    match /qr_tokens/{tokenId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || (
        isAttendanceStudent()
        && request.resource.data.keys().hasAll([
            'studentId','empNo','name','courseId','date','session',
            'used','issuedAt','expiresAt'
          ])
        && request.resource.data.used == false
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.empNo is string && request.resource.data.empNo.size() <= 20
        // 본인 empNo 만 허용 — custom token claim 의 empNos list 와 매칭
        && 'empNos' in request.auth.token
        && request.resource.data.empNo in request.auth.token.empNos
        && request.resource.data.name is string && request.resource.data.name.size() <= 50
        && request.resource.data.courseId is string && request.resource.data.courseId.size() <= 100
        && request.resource.data.date is string && request.resource.data.date.size() == 10
        && request.resource.data.session is string && request.resource.data.session in ['single','morning','afternoon']
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.expiresAt < request.time + duration.value(15, 'm')
      );
      allow update, delete: if isAdmin();
    }

    // ───────────── Rate limit (Cloud Function 전용) ─────────────
    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    // ───────────── collectionGroup: 학생 검색 (로그인) ─────────────
    // 익명 사용자가 empNo로 학생 문서를 검색하려면 collectionGroup read가 필요.
    // 한계: 인증된 사용자라면 모든 과정의 학생을 열거할 수 있음.
    // 더 강한 보호가 필요하면 학생 검색을 Cloud Function으로 이전할 것.
    match /{path=**}/students/{studentId} {
      allow read: if isAuthenticated();
    }

  }
}
