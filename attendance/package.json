{
  "name": "hrd-attendance-dev",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n \"EMU,WEB\" -c \"cyan,green\" \"firebase emulators:start --only firestore,auth --project hrd-data\" \"serve . --listen 3000 --ssl-cert 192.168.123.119+1.pem --ssl-key 192.168.123.119+1-key.pem\"",
    "emulator": "firebase emulators:start --only firestore,auth --project hrd-data",
    "start": "serve . --listen 3000 --ssl-cert 192.168.123.119+1.pem --ssl-key 192.168.123.119+1-key.pem",
    "serve-only": "serve . --listen 3000"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "serve": "^14.2.4"
  }
}
